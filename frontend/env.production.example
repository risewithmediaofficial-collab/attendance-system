# Frontend Environment Configuration

# API Configuration
VITE_API_BASE_URL="http://localhost:4000/api"

# Application Configuration
VITE_APP_NAME="RISE WITH MEDIA"
VITE_APP_VERSION="1.0.0"

# Map Configuration for GPS Attendance
VITE_OFFICE_LAT="12.9716"
VITE_OFFICE_LNG="77.5946"
VITE_OFFICE_RADIUS="100"

# Feature Flags
VITE_ENABLE_GPS_ATTENDANCE="true"
VITE_ENABLE_NOTIFICATIONS="true"
VITE_ENABLE_ANALYTICS="true"

# Theme Configuration
VITE_DEFAULT_THEME="dark"
VITE_PRIMARY_COLOR="#3b82f6"

# Upload Configuration
VITE_MAX_FILE_SIZE="5242880"  # 5MB in bytes
VITE_ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# Analytics (if using external service)
VITE_ANALYTICS_ID=""

# Debug Mode
VITE_DEBUG="false"
