# Backend Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
# Atlas -> Connect -> Drivers -> copy connection string, then replace <username> and <password>
# Database name at the end of the path (before ?) should match your app, e.g. member-tracker
MONGODB_URI="mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST/member-tracker?retryWrites=true&w=majority"

# JWT Configuration
JWT_SECRET="use-a-long-random-string-in-production"
JWT_REFRESH_SECRET="your-super-secure-refresh-token-secret-key"

# Server Configuration
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Email Configuration (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@risewithmedia.com"

# CORS Configuration
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# Attendance Configuration
OFFICE_START_TIME="09:00"
OFFICE_END_TIME="18:00"
LATE_THRESHOLD="15"  # minutes
HALF_DAY_THRESHOLD="4"  # hours
AUTO_CHECKOUT_TIME="18:30"
TIMEZONE="Asia/Kolkata"

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Logging
LOG_LEVEL="info"
LOG_FILE_PATH="./logs/app.log"
