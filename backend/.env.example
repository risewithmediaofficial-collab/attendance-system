# Copy to .env and fill in your Atlas values (Database Access user + Network Access IP allowlist).

# Atlas → Connect → Drivers → copy connection string, then replace <username> and <password>.
# Database name at the end of the path (before ?) should match your app, e.g. member-tracker
MONGODB_URI="mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST/member-tracker?retryWrites=true&w=majority"

JWT_SECRET="use-a-long-random-string-in-production"
PORT=4000
